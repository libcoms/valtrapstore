generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  user
  operator
  admin
}

enum OrderStatus {
  new
  accepted
  in_progress
  done
}

enum ProductCategory {
  valtrap
  ushki
}

enum ValtrapType {
  konkur
  vyezdka
  universalny
  pony
}

model User {
  id        String   @id @default(cuid())
  email     String?  @unique
  name      String?
  phone     String?
  role      Role     @default(user)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  orders    Order[]
}

model Product {
  id           String          @id @default(cuid())
  name         String
  description  String?
  category     ProductCategory
  valtrapType  ValtrapType?
  price        Int
  images       String[]
  colors       String[]
  sizes        String[]
  manufacturer String?
  inStock      Boolean         @default(true)
  isSet        Boolean         @default(false)
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
}

model Order {
  id        String      @id @default(cuid())
  status    OrderStatus @default(new)
  total     Int
  name      String
  phone     String
  address   String
  comment   String?
  items     Json
  userId    String?
  user      User?       @relation(fields: [userId], references: [id])
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
}
